{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/mail-watch-renew",
      "schedule": "0 5 * * *"
    }
  ],
  "framework": "nextjs",
  "functions": {
    "src/app/api/queues/mail-sync/route.ts": {
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "mail-sync"
        }
      ]
    }
  },
  "installCommand": "pnpm install --frozen-lockfile"
}
