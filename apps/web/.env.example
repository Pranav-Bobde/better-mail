# Copy to .env.local and fill in. .env.local is git-ignored.
# Non-DB values may be shared across envs for now; DB URLs must be segregated.

# ── Database (Neon) ──────────────────────────────────────────────
# LOCAL DEV MUST USE THE NEON `dev` BRANCH — never the prod branch.
#   bunx neonctl connection-string dev --project-id <id> --pooled
# staging/prod DATABASE_URL live ONLY in Vercel env vars (Preview/Production),
# never here or in .env.local. See AGENTS.md "Database & environments (Neon)".
DATABASE_URL="postgresql://user:password@<neon-dev-branch-host>/neondb?sslmode=require&channel_binding=require"

# ── App / auth ───────────────────────────────────────────────────
APP_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:4000"
BETTER_AUTH_URL="http://localhost:4000"
BETTER_AUTH_SECRET="" # 32+ char random secret

# ── Google / Gmail OAuth ─────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
GMAIL_OAUTH_REFRESH_TOKEN=""
GMAIL_PUBSUB_TOPIC=""
GMAIL_PUBSUB_TOPIC_NAME=""
GMAIL_PUBSUB_VERIFICATION_TOKEN=""
GMAIL_WATCH_LABEL_IDS=""
GMAIL_DEMO_USER=""
GMAIL_DEMO_STATE_FILE=""

# ── AI / infra ───────────────────────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_MODEL=""
ABLY_API_KEY=""
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="ai-email-client"
LANGSMITH_TRACING="false"
COPILOTKIT_TELEMETRY_DISABLED="true"
